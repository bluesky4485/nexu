FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl git && \
    rm -rf /var/lib/apt/lists/*

RUN npm install -g openclaw@latest --omit=optional

RUN mkdir -p /etc/openclaw

COPY scripts/gateway-entrypoint.sh /usr/local/bin/gateway-entrypoint.sh
RUN chmod +x /usr/local/bin/gateway-entrypoint.sh

ENV NODE_ENV=production

EXPOSE 18789

ENTRYPOINT ["gateway-entrypoint.sh"]
